{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDirs": [".", "./.react-router/types"],
    "outDir": "./build",
    "types": ["node", "vite/client", "mdx"],
    "paths": {
      "~/*": ["./app/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.mdx", ".react-router/types/**/*"],
  "exclude": ["node_modules", "build"]
}

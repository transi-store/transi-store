DOMAIN_ROOT=http://localhost:5173

# Database - local development for docker compose
# DB_PORT=5432
# DB_DATABASE=transi-store
# DB_USER=transi-store
# DB_PASSWORD=transi-store

# Database connection string for website and scripts
DATABASE_URL=postgresql://transi-store:transi-store@postgres:5432/transi-store

# OAuth2 - JWT-based authentication
# Note: access_token must be a JWT with "sub" claim containing user ID
MAPADO_CLIENT_ID=your-client-id
MAPADO_CLIENT_SECRET=your-client-secret

# Google OAuth (optional)
# Get your credentials at: https://console.cloud.google.com/apis/credentials > Create Credentials > OAuth 2.0 Client IDs > Authorized redirect URIs: your-domain-root:your-port/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (optional) 
# Get your creadentials at: https://github.com/settings/developers > New OAuth App > Authorization callback URL: your-domain-root:your-port/auth/github/callback
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Session secret
SESSION_SECRET=your-session-secret-change-this-in-production

# Encryption key for sensitive data (must be 64-character hexadecimal string)
ENCRYPTION_KEY=your-64-character-hexadecimal-encryption-key

# Optional email notification settings (Brevo SMTP)
# If ADMIN_NOTIFICATION_EMAIL is empty, no admin email is sent when new users join.
ADMIN_NOTIFICATION_EMAIL=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=
EMAIL_FROM=

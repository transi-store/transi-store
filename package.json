{
  "name": "transi-store",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "yarn workspace @transi-store/website dev",
    "build": "yarn workspace @transi-store/website build",
    "build:common": "yarn workspace @transi-store/common build",
    "build:cli": "yarn build:common && yarn workspace @transi-store/cli build && yarn build:cli:schema",
    "build:cli:schema": "node ./scripts/create-json-schema.mjs",
    "start": "yarn workspace @transi-store/website start",
    "download-translations": "yarn workspace @transi-store/website download-translations",
    "lint:eslint": "eslint .",
    "lint:types": "yarn build:common && yarn workspace @transi-store/website lint:types && yarn workspace @transi-store/common lint:types && yarn workspace @transi-store/cli lint:types",
    "knip": "yarn workspace @transi-store/website react-router typegen && knip",
    "db:generate": "yarn workspace @transi-store/website db:generate",
    "db:push": "yarn workspace @transi-store/website db:push",
    "db:studio": "yarn workspace @transi-store/website db:studio",
    "db:setup-search": "./scripts/enable-fuzzy-search.sh",
    "test": "yarn build:common && yarn workspace @transi-store/website test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@transi-store/common": "workspace:^",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "{apps,docs,packages,scripts}/**/*.{js,ts,tsx,json,css,md}": "prettier --write"
  }
}
